page {
  min-height: 100vh;
  background: #ffffff;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 28rpx;
}

button {
  box-sizing: border-box;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  line-height: normal;
}

button::after {
  border: 0;
}

.page {
  box-sizing: border-box;
  padding: calc(32rpx + env(safe-area-inset-top)) 28rpx calc(180rpx + env(safe-area-inset-bottom));
}

.section {
  margin-bottom: 28rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.muted {
  color: #64748b;
}

.card {
  padding: 26rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fee2e2;
  color: #ef4444;
  font-size: 24rpx;
}

.danger-pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fee2e2;
  color: #b91c1c;
  font-size: 24rpx;
}

.success-pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #dcfce7;
  color: #15803d;
  font-size: 24rpx;
}

.primary-button {
  min-height: 84rpx;
  border-radius: 14rpx;
  background: #ef4444;
  color: #ffffff;
  font-weight: 700;
  line-height: 84rpx;
}

.panel-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.panel-card {
  box-sizing: border-box;
  width: calc((100% - 16rpx) / 2);
  padding: 26rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  background: #ffffff;
}

.big-number {
  margin-bottom: 8rpx;
  font-size: 44rpx;
  font-weight: 800;
}

.progress-track {
  height: 20rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e2e8f0;
}

.progress-fill {
  height: 20rpx;
  border-radius: 999rpx;
  background: #ef4444;
}

.ghost-button {
  min-height: 76rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 14rpx;
  background: #ffffff;
  color: #334155;
  line-height: 76rpx;
}

.input {
  box-sizing: border-box;
  width: 100%;
  min-height: 80rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 14rpx;
  background: #ffffff;
}
