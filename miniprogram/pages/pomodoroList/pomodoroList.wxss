.pomodoro-page {
  min-height: 100vh;
  background: #f6f7fb;
}

.pomodoro-scroll {
  box-sizing: border-box;
  height: 100vh;
  padding: calc(30rpx + env(safe-area-inset-top)) 28rpx calc(56rpx + env(safe-area-inset-bottom));
}

.pomodoro-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.page-title,
.page-subtitle,
.record-title,
.record-meta,
.record-duration,
.empty {
  display: block;
}

.page-title {
  color: #111827;
  font-size: 44rpx;
  font-weight: 900;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 25rpx;
}

.start-btn {
  min-width: 116rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: #ef4444;
  color: #ffffff;
  font-size: 25rpx;
  line-height: 58rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.record-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  box-sizing: border-box;
  padding: 26rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 30rpx rgba(15, 23, 42, 0.06);
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.record-meta {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 24rpx;
}

.record-duration {
  color: #ef4444;
  font-size: 30rpx;
  font-weight: 900;
}

.empty {
  margin-top: 120rpx;
  color: #94a3b8;
  font-size: 28rpx;
  text-align: center;
}

.pomodoro-bottom-spacer {
  height: 110rpx;
}
