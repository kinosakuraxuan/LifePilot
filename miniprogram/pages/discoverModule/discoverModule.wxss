.module-page {
  min-height: 100vh;
  background: #f6f7fb;
}

.module-scroll {
  box-sizing: border-box;
  height: 100vh;
  padding: calc(30rpx + env(safe-area-inset-top)) 28rpx calc(56rpx + env(safe-area-inset-bottom));
}

.module-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.back-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  min-width: 64rpx;
  min-height: 64rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #111827;
  font-size: 42rpx;
  line-height: 64rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.08);
}

.module-title,
.module-subtitle,
.metric-value,
.metric-label,
.section-title,
.section-sub,
.record-title,
.record-meta,
.record-duration,
.empty {
  display: block;
}

.module-title {
  color: #111827;
  font-size: 44rpx;
  font-weight: 900;
}

.module-subtitle {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 24rpx;
}

.metric-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.metric-card {
  box-sizing: border-box;
  width: calc((100% - 18rpx) / 2);
  padding: 26rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.06);
}

.metric-value {
  color: #111827;
  font-size: 38rpx;
  font-weight: 900;
}

.metric-label {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
}

.chart-card,
.records-section {
  box-sizing: border-box;
  margin-top: 24rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.06);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 900;
}

.section-sub {
  color: #94a3b8;
  font-size: 22rpx;
}

.large-chart {
  position: relative;
  height: 260rpx;
  overflow: hidden;
}

.large-chart::before {
  position: absolute;
  right: 0;
  bottom: 20rpx;
  left: 0;
  height: 1rpx;
  background: rgba(148, 163, 184, 0.35);
  content: "";
}

.large-chart::after {
  position: absolute;
  top: 18rpx;
  bottom: 20rpx;
  left: 20rpx;
  width: 1rpx;
  background: rgba(148, 163, 184, 0.28);
  content: "";
}

.large-segment,
.large-point {
  position: absolute;
  background: #ef4444;
}

.large-segment {
  height: 5rpx;
  border-radius: 999rpx;
  transform-origin: 0 50%;
}

.large-point {
  width: 14rpx;
  height: 14rpx;
  margin-top: -7rpx;
  margin-left: -7rpx;
  border-radius: 50%;
  box-shadow: 0 0 0 6rpx rgba(239, 68, 68, 0.12);
}

.record-btn {
  min-width: 132rpx;
  height: 54rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 23rpx;
  line-height: 54rpx;
}

.record-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.record-card:last-child {
  border-bottom: 0;
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
}

.record-meta {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
}

.record-duration {
  color: #ef4444;
  font-size: 28rpx;
  font-weight: 900;
}

.empty {
  padding: 40rpx 0;
  color: #94a3b8;
  font-size: 26rpx;
  text-align: center;
}

.module-bottom-spacer {
  height: 96rpx;
}
