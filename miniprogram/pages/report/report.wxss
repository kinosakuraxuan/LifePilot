.report-page {
  box-sizing: border-box;
  height: 100vh;
  padding: calc(30rpx + env(safe-area-inset-top)) 28rpx calc(56rpx + env(safe-area-inset-bottom));
  background: #f6f7fb;
}

.report-hero {
  box-sizing: border-box;
  margin-bottom: 22rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  border-radius: 26rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(15, 23, 42, 0.06);
}

.page-title,
.page-subtitle,
.metric-value,
.metric-label,
.section-title-text,
.module-value,
.module-label,
.report-summary,
.next-focus,
.daily-date,
.daily-meta,
.share-text,
.empty-line {
  display: block;
}

.page-title {
  color: #111827;
  font-size: 46rpx;
  font-weight: 900;
}

.page-subtitle {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 25rpx;
}

.hero-image {
  display: block;
  width: 100%;
  height: 240rpx;
  margin-top: 22rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.metric-grid,
.module-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.metric-card {
  box-sizing: border-box;
  width: calc((100% - 16rpx) / 2);
  padding: 24rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  border-radius: 20rpx;
  background: #ffffff;
}

.metric-value {
  color: #111827;
  font-size: 36rpx;
  font-weight: 900;
}

.metric-label {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
}

.section-block {
  margin-top: 26rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.section-title-text {
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
}

.mini-btn {
  min-width: 176rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: #111827;
  color: #ffffff;
  font-size: 23rpx;
  line-height: 58rpx;
}

.mini-btn.ghost {
  border: 1rpx solid #cbd5e1;
  background: #ffffff;
  color: #334155;
}

.module-card {
  box-sizing: border-box;
  width: calc((100% - 16rpx) / 2);
  padding: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
}

.module-card.study { background: linear-gradient(160deg, #fff1f2 0%, #ffffff 80%); }
.module-card.sport { background: linear-gradient(160deg, #ecfdf5 0%, #ffffff 80%); }
.module-card.sleep { background: linear-gradient(160deg, #eef2ff 0%, #ffffff 80%); }
.module-card.entertainment { background: linear-gradient(160deg, #fff7ed 0%, #ffffff 80%); }
.module-card.schedule { background: linear-gradient(160deg, #f8fafc 0%, #ffffff 80%); }
.module-card.note { background: linear-gradient(160deg, #f0f9ff 0%, #ffffff 80%); }
.module-card.focus { background: linear-gradient(160deg, #fee2e2 0%, #ffffff 80%); }

.module-value {
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
}

.module-label {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
}

.insight-card,
.list-card,
.daily-card,
.share-card {
  box-sizing: border-box;
  padding: 24rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(15, 23, 42, 0.05);
}

.report-summary {
  color: #334155;
  font-size: 28rpx;
  line-height: 1.65;
}

.next-focus {
  margin-top: 18rpx;
  color: #ef4444;
  font-size: 25rpx;
  font-weight: 800;
}

.list-card {
  margin-bottom: 14rpx;
  color: #334155;
  font-size: 26rpx;
  line-height: 1.55;
}

.list-card.warn {
  background: #fff7ed;
  color: #9a3412;
}

.empty-line {
  padding: 28rpx;
  color: #94a3b8;
  text-align: center;
}

.daily-card {
  margin-bottom: 14rpx;
}

.daily-date {
  color: #111827;
  font-size: 26rpx;
  font-weight: 900;
}

.daily-meta {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 23rpx;
  line-height: 1.45;
}

.share-block {
  margin-bottom: 20rpx;
}

.share-text {
  min-height: 160rpx;
  color: #334155;
  font-size: 26rpx;
  line-height: 1.6;
  white-space: pre-wrap;
}

.copy-btn {
  width: 100%;
  height: 76rpx;
  margin-top: 20rpx;
  border-radius: 16rpx;
  background: #ef4444;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 76rpx;
}

.bottom-spacer {
  height: 120rpx;
}
