<view class="page report-page">
  <view class="section">
    <view class="section-title">周报</view>
    <view class="report-grid">
      <view class="report-card">
        <text class="report-value">{{stats.studyHours}}小时</text>
        <text class="muted">学习</text>
      </view>
      <view class="report-card">
        <text class="report-value">{{stats.entertainmentHours}}小时</text>
        <text class="muted">娱乐</text>
      </view>
      <view class="report-card">
        <text class="report-value">{{stats.exerciseMinutes}}分钟</text>
        <text class="muted">运动</text>
      </view>
      <view class="report-card">
        <text class="report-value">{{stats.sleepAvg}}小时</text>
        <text class="muted">平均睡眠</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">五维状态</view>
    <view class="card radar-card">
      <view class="radar-bg"></view>
      <view class="radar-point {{item.cls}}" wx:for="{{radar}}" wx:key="label" style="--v: {{item.value}}%;">
        <view class="radar-dot"></view>
        <text class="radar-label">{{item.label}} {{item.value}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">学习柱状图</view>
    <view class="card chart-card">
      <view class="bar-row" wx:for="{{studyBars}}" wx:key="label">
        <text class="bar-label">{{item.label}}</text>
        <view class="bar-track">
          <view class="bar-fill" style="width: {{item.width}}%;"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">睡眠趋势</view>
    <view class="card sleep-chart">
      <view class="sleep-column" wx:for="{{sleepLine}}" wx:key="label">
        <view class="sleep-bar" style="height: {{item.height}}%;"></view>
        <text class="sleep-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">生活占比</view>
    <view class="card stack">
      <view wx:for="{{balanceDonut}}" wx:key="label">
        <view class="dist-row">
          <text>{{item.label}}</text>
          <text>{{item.value}}%</text>
        </view>
        <view class="bar-track">
          <view class="bar-fill {{item.cls}}" style="width: {{item.value}}%;"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">笔记分析</view>
    <view class="card">
      <view class="row">
        <view>
          <text class="auth-title">允许 AI 阅读本周笔记</text>
          <text class="muted">用于关键词、情绪变化和建议生成。</text>
        </view>
        <switch checked="{{diaryAuth}}" bindchange="toggleDiaryAuth" />
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">建议</view>
    <view class="card">
      <text class="advice">{{advice}}</text>
    </view>
  </view>
</view>
