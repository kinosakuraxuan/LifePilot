<view class="page report-page">
  <view class="section">
    <view class="section-title">本周数据化周报</view>
    <view class="report-grid">
      <view class="report-card">
        <view class="report-value">{{stats.studyHours}}h</view>
        <view class="muted">学习总时长</view>
      </view>
      <view class="report-card">
        <view class="report-value">{{stats.entertainmentHours}}h</view>
        <view class="muted">娱乐总时长</view>
      </view>
      <view class="report-card">
        <view class="report-value">{{stats.exerciseMinutes}}m</view>
        <view class="muted">运动总时长</view>
      </view>
      <view class="report-card">
        <view class="report-value">{{stats.sleepAvg}}h</view>
        <view class="muted">平均睡眠</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">五维雷达图</view>
    <view class="card radar-card">
      <view class="radar-bg"></view>
      <view class="radar-point {{item.cls}}" wx:for="{{radar}}" wx:key="label" style="--v: {{item.value}}%;">
        <view class="radar-dot"></view>
        <view class="radar-label">{{item.label}} {{item.value}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">学习柱状图</view>
    <view class="card chart-card">
      <view class="bar-row" wx:for="{{studyBars}}" wx:key="label">
        <view class="bar-label">{{item.label}}</view>
        <view class="bar-track">
          <view class="bar-fill" style="width: {{item.width}}%;"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">睡眠趋势图</view>
    <view class="card sleep-chart">
      <view class="sleep-column" wx:for="{{sleepLine}}" wx:key="label">
        <view class="sleep-bar" style="height: {{item.height}}%;"></view>
        <view class="sleep-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">生活占比图</view>
    <view class="card stack">
      <view wx:for="{{balanceDonut}}" wx:key="label">
        <view class="dist-row">
          <text>{{item.label}}</text>
          <text>{{item.value}}%</text>
        </view>
        <view class="bar-track">
          <view class="bar-fill {{item.cls}}" style="width: {{item.value}}%;"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">日记参与分析</view>
    <view class="card">
      <view class="row">
        <view>
          <view class="auth-title">允许 AI 读取本周日记与灵感</view>
          <view class="muted">用于生成关键词、情绪变化和成长建议</view>
        </view>
        <switch checked="{{diaryAuth}}" bindchange="toggleDiaryAuth" />
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">AI 周报建议</view>
    <view class="card">
      <view class="advice">{{advice}}</view>
    </view>
  </view>
</view>
