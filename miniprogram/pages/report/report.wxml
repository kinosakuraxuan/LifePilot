<scroll-view class="report-page" type="list" scroll-y="true">
  <view class="report-hero">
    <view>
      <text class="page-title">本周周报</text>
      <text class="page-subtitle">{{rangeText}}</text>
    </view>
    <image class="hero-image" src="{{decoImage}}" mode="aspectFill"></image>
  </view>

  <view class="metric-grid">
    <view class="metric-card" wx:for="{{metricCards}}" wx:key="label">
      <text class="metric-value">{{item.value}}</text>
      <text class="metric-label">{{item.label}}</text>
    </view>
  </view>

  <view class="section-block">
    <text class="section-title-text">模块概览</text>
    <view class="module-grid">
      <view class="module-card {{item.cls}}" wx:for="{{moduleCards}}" wx:key="label">
        <text class="module-value">{{item.value}}</text>
        <text class="module-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="section-block">
    <view class="section-head">
      <text class="section-title-text">AI 总结</text>
      <button class="mini-btn" loading="{{generating}}" disabled="{{generating}}" bindtap="generateAIReport">
        <text>{{generating ? '生成中' : '生成 AI 周报'}}</text>
      </button>
    </view>
    <view class="insight-card">
      <text class="report-summary">{{report.summary}}</text>
      <text class="next-focus">下周重点：{{report.nextWeekFocus}}</text>
    </view>
  </view>

  <view class="section-block">
    <text class="section-title-text">亮点</text>
    <view class="list-card" wx:for="{{report.highlights}}" wx:key="*this"><text>{{item}}</text></view>
    <view class="empty-line" wx:if="{{!report.highlights.length}}"><text>暂无亮点，继续记录后会更清晰。</text></view>
  </view>

  <view class="section-block">
    <text class="section-title-text">风险与建议</text>
    <view class="list-card warn" wx:for="{{report.risks}}" wx:key="*this"><text>{{item}}</text></view>
    <view class="list-card" wx:for="{{report.suggestions}}" wx:key="*this"><text>{{item}}</text></view>
  </view>

  <view class="section-block">
    <text class="section-title-text">日程洞察</text>
    <view class="list-card" wx:for="{{report.scheduleInsights}}" wx:key="*this"><text>{{item}}</text></view>
  </view>

  <view class="section-block">
    <text class="section-title-text">无边记洞察</text>
    <view class="list-card" wx:for="{{report.noteInsights}}" wx:key="*this"><text>{{item}}</text></view>
  </view>

  <view class="section-block">
    <text class="section-title-text">专注洞察</text>
    <view class="list-card" wx:for="{{report.focusInsights}}" wx:key="*this"><text>{{item}}</text></view>
  </view>

  <view class="section-block">
    <text class="section-title-text">每日趋势</text>
    <view class="daily-card" wx:for="{{daily}}" wx:key="date">
      <text class="daily-date">{{item.date}}</text>
      <text class="daily-meta">学习 {{item.studyMinutes}}min · 运动 {{item.sportMinutes}}min · 娱乐 {{item.entertainmentMinutes}}min · 日程 {{item.scheduleCount}}</text>
    </view>
  </view>

  <view class="section-block share-block">
    <view class="section-head">
      <text class="section-title-text">简易分享</text>
      <button class="mini-btn ghost" bindtap="generateShareText"><text>生成分享文案</text></button>
    </view>
    <view class="share-card">
      <text class="share-text">{{shareText}}</text>
      <button class="copy-btn" bindtap="copyShareText"><text>复制分享文案</text></button>
    </view>
  </view>

  <view class="bottom-spacer"></view>
</scroll-view>
