<view class="note-page">
  <view class="editor-topbar">
    <button class="top-action cancel-action" bindtap="cancelEdit"><text>取消</text></button>
    <button wx:if="{{pageMode === 'edit'}}" class="top-action delete-action" bindtap="deleteCurrentNote"><text>删除</text></button>
    <button wx:else class="top-action save-action" bindtap="saveDraftAndExit"><text>保存</text></button>
    <button class="top-action done-action" bindtap="finishEdit"><text>完成</text></button>
  </view>

  <scroll-view class="note-scroll" type="list" scroll-y="true">
    <view class="note-card">
      <picker mode="date" value="{{editingNoteDate}}" bindchange="onDateChange">
        <view class="note-meta">
          <view class="date-dot"></view>
          <text>{{editingNoteDateText}}</text>
        </view>
      </picker>

      <textarea
        class="note-editor"
        placeholder="写下想法、任务或任何线索"
        value="{{editingNoteContent}}"
        bindinput="updateNoteContent"
        adjust-position="{{true}}"
        show-confirm-bar="{{false}}"
        maxlength="-1"
      ></textarea>

      <view class="attachment-panel {{attachmentPanelOpen ? 'is-open' : ''}}">
        <button
          wx:for="{{attachmentOptions}}"
          wx:key="type"
          class="attachment-option"
          data-type="{{item.type}}"
          catchtap="handleAttachmentOption"
        >
          <view class="option-dot"></view>
          <text>{{item.label}}</text>
        </button>
      </view>

      <view class="attachment-preview" wx:if="{{editingNoteAttachments.length}}">
        <view
          wx:for="{{editingNoteAttachments}}"
          wx:key="id"
          class="attachment-chip"
          data-id="{{item.id}}"
          catchtap="removeAttachment"
        >
          <text>{{item.label}}</text>
        </view>
      </view>

      <button
        class="paperclip-button {{attachmentPanelOpen ? 'active' : ''}}"
        catchtap="toggleAttachmentPanel"
        aria-label="附件"
      >
        <view class="clip-loop"></view>
        <view class="clip-tail"></view>
      </button>
    </view>
  </scroll-view>
</view>
