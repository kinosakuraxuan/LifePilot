page {
  background: #f4f2ec;
}

.note-page {
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: calc(150rpx + env(safe-area-inset-top)) 30rpx calc(30rpx + env(safe-area-inset-bottom));
  overflow: hidden;
  color: #151515;
  background: #f4f2ec;
}

.editor-topbar {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 82rpx;
  margin-bottom: 20rpx;
}

.top-action {
  min-width: 150rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 24rpx;
  border: 2rpx solid #151515;
  border-radius: 999rpx;
  background: #ffffff;
  color: #151515;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 60rpx;
  text-align: center;
}

.top-action::after {
  border: 0;
}

.cancel-action,
.done-action,
.delete-action {
  color: #151515;
}

.delete-action {
  color: #ef4444;
}

.top-title {
  flex: 1;
  color: #151515;
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
}

.note-scroll {
  flex: 1 1 auto;
  height: 0;
}

.note-card {
  position: relative;
  box-sizing: border-box;
  min-height: calc(100vh - 220rpx - env(safe-area-inset-top) - env(safe-area-inset-bottom));
  padding: 32rpx 34rpx 146rpx;
  border: 3rpx solid rgba(21, 21, 21, 0.08);
  border-radius: 34rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 42rpx rgba(54, 42, 30, 0.08);
}

.note-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 54rpx;
  color: #111111;
  font-size: 34rpx;
  font-weight: 700;
}

.date-dot {
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid #111111;
  border-radius: 50%;
}

.note-editor {
  box-sizing: border-box;
  width: 100%;
  min-height: 680rpx;
  margin-top: 18rpx;
  padding: 0 0 34rpx;
  background: transparent;
  color: #171717;
  font-size: 34rpx;
  line-height: 1.7;
}

.attachment-panel {
  position: absolute;
  left: 32rpx;
  bottom: 118rpx;
  z-index: 5;
  width: 320rpx;
  padding: 12rpx 0;
  border: 2rpx solid rgba(21, 21, 21, 0.08);
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(35, 29, 23, 0.14);
  opacity: 0;
  pointer-events: none;
  transform: translateY(18rpx) scale(0.98);
  transition: opacity 160ms ease, transform 160ms ease;
}

.attachment-panel.is-open {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0) scale(1);
}

.attachment-option {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
  min-height: 72rpx;
  margin: 0;
  padding: 0 24rpx;
  background: transparent;
  color: #151515;
  font-size: 30rpx;
  line-height: 72rpx;
  text-align: left;
}

.attachment-option::after,
.paperclip-button::after {
  border: 0;
}

.option-dot {
  flex: 0 0 auto;
  width: 18rpx;
  height: 18rpx;
  border: 3rpx solid #8f8f8f;
  border-radius: 50%;
}

.attachment-list {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 10rpx;
  padding-bottom: 20rpx;
}

.image-attachments {
  position: relative;
  z-index: 2;
  margin-top: 10rpx;
  margin-bottom: 14rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #f7f6f1;
}

.attachment-section-title {
  display: block;
  margin-bottom: 14rpx;
  color: #171717;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  width: 100%;
}

.image-thumb {
  flex: 0 0 calc((100% - 42rpx) / 4);
  width: calc((100% - 42rpx) / 4);
  height: calc((100% - 42rpx) / 4);
  border-radius: 18rpx;
  background: #e8e4dc;
}

.attachment-item {
  position: relative;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-height: 88rpx;
  padding: 14rpx 18rpx;
  overflow: hidden;
  border-radius: 20rpx;
  background: #f7f6f1;
}

.attachment-thumb {
  flex: 0 0 auto;
  width: 82rpx;
  height: 82rpx;
  border-radius: 14rpx;
  background: #e8e4dc;
}

.attachment-kind-dot {
  flex: 0 0 auto;
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid #151515;
  border-radius: 50%;
}

.attachment-info {
  flex: 1 1 auto;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.attachment-title {
  color: #171717;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
}

.attachment-subtitle {
  overflow: hidden;
  color: #79746d;
  font-size: 24rpx;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scan-text-preview {
  white-space: normal;
  max-height: 96rpx;
}

.attachment-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 4;
  background: transparent;
}

.paperclip-button {
  position: absolute;
  left: 32rpx;
  bottom: 28rpx;
  z-index: 6;
  width: 72rpx;
  height: 72rpx;
  min-width: 72rpx;
  min-height: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: transparent;
}

.paperclip-button.active {
  background: #f2f0ea;
}

.clip-loop {
  position: absolute;
  left: 18rpx;
  top: 10rpx;
  width: 25rpx;
  height: 46rpx;
  border: 5rpx solid #151515;
  border-radius: 20rpx;
  transform: rotate(38deg);
}

.clip-tail {
  position: absolute;
  left: 33rpx;
  top: 17rpx;
  width: 14rpx;
  height: 34rpx;
  border: 4rpx solid #151515;
  border-left: 0;
  border-radius: 12rpx;
  transform: rotate(38deg);
}
