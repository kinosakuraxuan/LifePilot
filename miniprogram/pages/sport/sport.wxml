<view class="page">
  <view class="section">
    <view class="section-title">运动看板</view>
    <view class="panel-grid">
      <view class="panel-card">
        <view class="big-number">{{sport.todayMinutes}}m</view>
        <view class="muted">今日运动</view>
      </view>
      <view class="panel-card">
        <view class="big-number">{{sport.weeklyTimes}}/{{sport.goalTimes}}</view>
        <view class="muted">周目标次数</view>
      </view>
      <view class="panel-card">
        <view class="big-number">{{sport.calories}}</view>
        <view class="muted">估算消耗 kcal</view>
      </view>
      <view class="panel-card">
        <view class="big-number">{{sport.types.length}}</view>
        <view class="muted">运动类型</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">本周趋势</view>
    <view class="card stack">
      <view class="bar-row" wx:for="{{trend}}" wx:key="label">
        <view class="bar-label">{{item.label}}</view>
        <view class="progress-track">
          <view class="progress-fill sport-fill" style="width: {{item.value}}%;"></view>
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">类型记录</view>
    <view class="tag-row">
      <text class="success-pill" wx:for="{{sport.types}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">AI 健康建议</view>
    <view class="card advice">{{sport.advice}}</view>
  </view>

  <button class="primary-button" bindtap="addSport">记录一次运动</button>
</view>

