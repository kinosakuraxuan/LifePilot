.home-root {
  position: relative;
  height: 100vh;
  background: #ffffff;
}

.calendar-shell {
  height: 100vh;
  background: #ffffff;
  color: #111827;
}

.top-bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 158rpx;
  box-sizing: border-box;
  padding: 62rpx 32rpx 18rpx;
  color: #ef4444;
}

.month-left {
  max-width: 250rpx;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.2;
}

.month-text {
  display: inline-block;
}



.top-actions {
  position: absolute;
  right: 34rpx;
  top: 78rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  width: 164rpx;
  height: 72rpx;
}

.search-icon,
.top-add {
  flex: 0 0 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-sizing: border-box;
  width: 72rpx;
  min-width: 72rpx;
  max-width: 72rpx;
  height: 72rpx;
  min-height: 72rpx;
  max-height: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: transparent;
  color: #ef4444;
  font-size: 48rpx;
  line-height: 1;
}

.search-icon:active,
.top-add:active,
.boundless-corner-trigger:active,
.empty-action:active {
  transform: scale(0.96);
}

.top-add {
  margin: 0;
  padding: 0;
  background: transparent;
}

.search-icon:active,
.top-add:active {
  background: #fff1f2;
}

.top-add-symbol {
  display: block;
  line-height: 1;
}

.search-icon::after,
.top-add::after,
.boundless-corner-trigger::after,
.note-tool::after,
.swipe-delete::after {
  border: 0;
}

.search-shape {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #ef4444;
  border-radius: 50%;
}

.search-shape::after {
  content: "";
  position: absolute;
  right: -12rpx;
  bottom: -7rpx;
  width: 18rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #ef4444;
  transform: rotate(45deg);
}

.weekday-row {
  display: flex;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid #d1d5db;
}

.weekday {
  width: 14.285%;
  color: #111827;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
}

.simple-month {
  display: flex;
  flex-wrap: wrap;
  max-height: 50vh;
  overflow: hidden;
  background: #f7f7f8;
  transform-origin: 50% 50%;
}

.simple-month.month-flip-next {
  animation: monthNextIn 220ms ease-out;
}

.simple-month.month-flip-prev {
  animation: monthPrevIn 220ms ease-out;
}

.simple-day {
  position: relative;
  box-sizing: border-box;
  width: 14.285%;
  height: 104rpx;
  padding-top: 10rpx;
  border-bottom: 1rpx solid #dcdfe5;
  text-align: center;
}

.empty-day {
  visibility: hidden;
}

.date-number {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
}

.lunar {
  display: block;
  margin-top: 2rpx;
  color: #4b5563;
  font-size: 22rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  margin: 8rpx auto 0;
  border-radius: 50%;
  background: #c7c9cf;
}

.selected-day,
.today-selected {
  width: 88rpx;
  height: 88rpx;
  margin: 8rpx auto 0;
  padding-top: 8rpx;
  border-radius: 50%;
  color: #ffffff;
}

.selected-day {
  background: #000000;
}

.today-selected {
  background: #ef4444;
}

.selected-day .lunar,
.today-selected .lunar {
  color: #ffffff;
}

.selected-day .dot,
.today-selected .dot {
  display: none;
}

.agenda-area {
  min-height: 46vh;
  padding: 42rpx 44rpx;
  background: #ffffff;
}

.agenda-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 34rpx;
}

.agenda-summary-label,
.agenda-summary-title,
.agenda-summary-count {
  display: block;
}

.agenda-summary-label {
  color: #ef4444;
  font-size: 24rpx;
  font-weight: 800;
}

.agenda-summary-title {
  max-width: 480rpx;
  margin-top: 6rpx;
  overflow: hidden;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.agenda-summary-count {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #475569;
  font-size: 24rpx;
  font-weight: 800;
}

.swipe-row {
  position: relative;
  overflow: hidden;
  margin-bottom: 30rpx;
  border-radius: 0;
  background: #ffffff;
}

.swipe-action {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 88rpx;
  display: flex;
  justify-content: flex-end;
  background: transparent;
}

.swipe-edit,
.swipe-delete {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 100%;
  margin: 0;
  padding: 0;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
}

.swipe-edit {
  background: #111827 !important;
}

.swipe-delete {
  background: #ef4444 !important;
}

.swipe-content {
  position: relative;
  z-index: 1;
  box-sizing: border-box;
  width: 100%;
  background: #ffffff;
  transition: transform 180ms ease;
}

.swipe-content.is-open {
  transform: translateX(-88rpx);
}

.agenda-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 0;
  padding: 8rpx 10rpx;
  border-radius: 18rpx;
  transition: opacity 180ms ease, transform 180ms ease;
}

.agenda-item:active {
  transform: scale(0.99);
}

.agenda-item.just-added {
  animation: agendaAdded 1200ms ease-out;
}

.accent {
  width: 8rpx;
  height: 82rpx;
  border-radius: 999rpx;
  background: #facc15;
  transition: opacity 180ms ease, transform 180ms ease;
}

.agenda-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  min-height: 82rpx;
  min-width: 0;
}

.agenda-title {
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #111827;
  font-size: 34rpx;
  font-weight: 800;
  transition: opacity 180ms ease, transform 180ms ease;
}

.agenda-location {
  display: block;
  max-width: 420rpx;
  min-height: 30rpx;
  margin-top: 6rpx;
  overflow: hidden;
  color: #8b95a5;
  font-size: 24rpx;
  line-height: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.agenda-time {
  display: flex;
  flex-direction: column;
  color: #111827;
  font-size: 30rpx;
  line-height: 1.55;
  text-align: right;
  margin-right: 20rpx;
  margin-top: 0rpx;
  font-feature-settings: "tnum";
  transition: opacity 180ms ease, transform 180ms ease;
}

.agenda-status-active .accent {
  opacity: 1;
  transform: scaleY(1.08);
}

.agenda-status-active .agenda-title {
  color: #0f172a;
  font-weight: 900;
}

.agenda-status-ended {
  opacity: 0.78;
}

.agenda-status-ended .accent {
  opacity: 0.34;
}

.agenda-status-ended .agenda-title {
  color: #64748b;
}

.agenda-status-ended .agenda-time {
  color: #94a3b8;
}

.agenda-status-upcoming .agenda-time {
  color: #1f2937;
}

.empty-agenda {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 520rpx;
  color: #9ca3af;
  text-align: center;
}

.empty-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #fee2e2;
  color: #ef4444;
  font-size: 54rpx;
  font-weight: 700;
  line-height: 84rpx;
}

.empty-title {
  display: block;
  margin-top: 20rpx;
  color: #111827;
  font-size: 36rpx;
  font-weight: 900;
}

.empty-copy {
  display: block;
  max-width: 460rpx;
  margin-top: 10rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.45;
}

.empty-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.empty-action {
  min-width: 156rpx;
  height: 68rpx;
  margin: 0;
  padding: 0 22rpx;
  border: 1rpx solid #cbd5e1;
  border-radius: 999rpx;
  background: #ffffff;
  color: #334155;
  font-size: 26rpx;
  line-height: 68rpx;
}

.empty-action.primary {
  border-color: #ef4444;
  background: #ef4444;
  color: #ffffff;
}

.boundless-corner-trigger {
  position: fixed;
  right: 34rpx;
  bottom: calc(138rpx + env(safe-area-inset-bottom));
  z-index: 1200;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-width: 176rpx;
  height: 82rpx;
  margin: 0;
  padding: 0 14rpx;
  border: 1rpx solid rgba(234, 179, 8, 0.28);
  border-radius: 999rpx;
  background: #fffdf2;
  line-height: 1;
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.12);
  transition: transform 160ms ease, box-shadow 160ms ease, background-color 160ms ease;
}

.boundless-corner-trigger.is-empty-date {
  min-width: 176rpx;
  background: #fffdf2;
  box-shadow: 0 18rpx 42rpx rgba(234, 179, 8, 0.22);
}

.boundless-label {
  display: block;
  color: #a16207;
  font-size: 25rpx;
  font-weight: 900;
  white-space: nowrap;
}

.trigger-icon-box {
  width: 58rpx;
  height: 58rpx;
  border-radius: 0;
  background: transparent;
  padding: 0;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: none;
}

.sheet-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1300;
  pointer-events: none;
  background: rgba(17, 24, 39, 0);
  transition: background 180ms ease;
}

.sheet-mask.is-open {
  pointer-events: auto;
  background: rgba(17, 24, 39, 0.2);
}

.day-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1400;
  box-sizing: border-box;
  padding: 14rpx 28rpx calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -18rpx 58rpx rgba(15, 23, 42, 0.2);
  opacity: 0;
  pointer-events: none;
  transform: translateY(104%);
  transition: transform 220ms ease, opacity 180ms ease, height 180ms ease;
}

.day-sheet.is-open {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

.day-sheet.full {
  height: 100vh;
}

.day-sheet.three-quarter {
  height: 75vh;
}

.day-sheet.half {
  height: 50vh;
}

.sheet-handle-zone {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 46rpx;
}

.sheet-handle {
  width: 112rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #c7c9cf;
}

.sheet-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 76rpx;
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
  gap: 18rpx;
}

.sheet-title > text {
  flex: 1;
  min-width: 0;
}

.note-sheet-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.sheet-action-button {
  min-width: 96rpx;
  height: 62rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #111827;
  font-size: 26rpx;
  line-height: 62rpx;
  white-space: nowrap;
}

.sheet-action-button.primary {
  background: #111827;
  color: #ffffff;
}

.sheet-action-button.danger {
  background: #fee2e2;
  color: #dc2626;
}

.sheet-action-button::after {
  border: 0;
}

.sheet-body {
  height: calc(100% - 122rpx);
}

.sheet-scroll,
.note-editor-wrap {
  height: 100%;
}

.note-sheet-scroll {
  box-sizing: border-box;
  padding: 18rpx 4rpx 96rpx;
}

.note-sheet-content {
  display: block;
  color: #111827;
  font-size: 30rpx;
  line-height: 1.75;
  white-space: pre-wrap;
  word-break: break-word;
}

.note-sheet-editor {
  box-sizing: border-box;
  width: 100%;
  height: 100%;
  padding: 22rpx;
  border-radius: 20rpx;
  color: #0f172a;
  background: #f8fafc;
  font-size: 30rpx;
  line-height: 1.7;
}

@keyframes monthNextIn {
  from {
    opacity: 0;
    transform: translateY(28rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes monthPrevIn {
  from {
    opacity: 0;
    transform: translateY(-28rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes agendaAdded {
  0% {
    background: #fee2e2;
    transform: scale(0.985);
  }
  55% {
    background: #fff1f2;
    transform: scale(1);
  }
  100% {
    background: transparent;
    transform: scale(1);
  }
}
