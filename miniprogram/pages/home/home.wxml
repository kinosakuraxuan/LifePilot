<view class="calendar-shell">
  <view class="top-bar">
    <view class="month-left">
      <text class="month-text">{{monthTitle}}</text>
    </view>
    <view class="top-actions">
      <view class="search-icon" bindtap="goSearch">⌕</view>
      <button class="top-add" bindtap="addSchedule">＋</button>
    </view>
  </view>

  <view class="weekday-row">
    <view class="weekday" wx:for="{{weekdays}}" wx:key="*this">{{item}}</view>
  </view>

  <view class="simple-month" bindtouchstart="onMonthTouchStart" bindtouchend="onMonthTouchEnd">
    <view class="simple-day {{item.disabled ? 'empty-day' : ''}} {{item.selected && !item.isToday ? 'selected-day' : ''}} {{item.selected && item.isToday ? 'today-selected' : ''}}" wx:for="{{days}}" wx:key="id" data-day="{{item.day}}" bindtap="selectDay">
      <view class="date-number" wx:if="{{!item.disabled}}">{{item.day}}</view>
      <view class="lunar" wx:if="{{!item.disabled}}">{{item.lunar}}</view>
      <view class="dot" wx:if="{{item.hasCourse}}"></view>
    </view>
  </view>

  <view class="agenda-area">
    <block wx:if="{{events.length}}">
      <view class="swipe-row" wx:for="{{events}}" wx:key="id" data-id="{{item.id}}" bindtouchstart="onAgendaTouchStart" bindtouchend="onAgendaTouchEnd">
        <view class="swipe-action">
          <button class="swipe-delete" data-id="{{item.id}}" catchtap="deleteSchedule">删除</button>
        </view>
        <view class="agenda-item swipe-content {{swipedId === item.id ? 'is-open' : ''}}">
          <view class="accent"></view>
          <view class="agenda-main">
            <view class="agenda-title">{{item.title}}</view>
            <view class="agenda-location">{{item.location}}</view>
          </view>
          <view class="agenda-time">
            <view>{{item.start}}</view>
            <view>{{item.end}}</view>
          </view>
        </view>
      </view>
    </block>
    <view class="empty-agenda" wx:else>无日程</view>
  </view>
</view>
