.confirm-card {
  border-color: #93c5fd;
  background: #fee2e2;
}

.field {
  color: #475569;
  font-weight: 700;
}

.mini-button {
  min-width: 150rpx;
  height: 58rpx;
  border-radius: 12rpx;
  background: #e0f2fe;
  color: #0369a1;
  font-size: 24rpx;
  line-height: 58rpx;
}

.item-title {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.schedule-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.delete-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  min-width: 58rpx;
  min-height: 58rpx;
  padding: 0;
  border-radius: 50%;
  background: #fee2e2;
  color: #b91c1c;
  font-size: 24rpx;
  line-height: 1;
}
