<view class="search-page">
  <view class="search-bar">
    <view class="search-symbol">⌕</view>
    <input class="search-input" value="{{keyword}}" placeholder="搜索日程、提醒、地点或时间" confirm-type="search" bindinput="onInput" bindconfirm="onConfirm" focus />
    <button class="clear-button" wx:if="{{keyword}}" bindtap="clearKeyword">×</button>
  </view>

  <button class="search-button" bindtap="search">搜索</button>

  <view class="result-list" wx:if="{{results.length}}">
    <view class="result-item" wx:for="{{results}}" wx:key="id">
      <view class="result-main">
        <view class="result-title">{{item.title}}</view>
        <view class="result-meta">{{item.date || '未设置日期'}} {{item.startTime || item.start || ''}} {{item.location || ''}}</view>
      </view>
      <view class="result-tag">{{item.source || item.type || '事项'}}</view>
    </view>
  </view>

  <view class="empty-search" wx:elif="{{searched && !loading}}">没有找到匹配结果</view>
  <view class="empty-search" wx:elif="{{loading}}">搜索中...</view>
  <view class="empty-search" wx:else>输入关键字查找日程和提醒事项</view>
</view>

