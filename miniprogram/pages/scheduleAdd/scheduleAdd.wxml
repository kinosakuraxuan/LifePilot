<view class="add-page">
  <view class="add-top" style="{{topBarStyle}}">
    <button class="plain cancel" style="{{leftActionStyle}}" bindtap="navigateBack"><text>取消</text></button>
    <view class="add-title"><text>{{pageTitle}}</text></view>
    <button class="plain add-action" style="{{rightActionStyle}}" bindtap="saveSchedule"><text>{{actionText}}</text></button>
  </view>

  <scroll-view class="form-scroll {{pageMode === 'edit' ? 'edit-scroll' : ''}}" type="list" scroll-y="true">
    <view class="form-content {{pageMode === 'edit' ? 'edit-content' : ''}}">
      <view class="form-section-head">
        <text class="section-kicker">必要信息</text>
        <text class="section-hint">先写清楚要做什么</text>
      </view>
      <view class="form-card title-card">
        <view class="input-row {{formErrorTitle ? 'has-error' : ''}} {{activeField === 'title' ? 'is-active' : ''}}">
          <text class="field-icon">事</text>
          <input class="field-input title-input" placeholder="标题" value="{{title}}" data-key="title" data-field="title" bindinput="updateField" bindfocus="setActiveField" bindblur="clearActiveField" />
        </view>
        <text class="field-error" wx:if="{{formErrorTitle}}">{{formErrorTitle}}</text>
        <view class="input-row no-border {{activeField === 'location' ? 'is-active' : ''}}">
          <text class="field-icon muted-icon">地</text>
          <input class="field-input no-border" placeholder="地点或线上会议" value="{{location}}" data-key="location" data-field="location" bindinput="updateField" bindfocus="setActiveField" bindblur="clearActiveField" />
        </view>
      </view>

      <view class="form-section-head">
        <text class="section-kicker">时间</text>
        <text class="section-hint">默认 1 小时，可随时调整</text>
      </view>
      <view class="form-card time-card">
        <view class="form-row">
          <view class="row-label-wrap"><text class="field-icon">全</text><text class="row-label">全天</text></view>
          <switch checked="{{allDay}}" color="#ef4444" bindchange="toggleAllDay" />
        </view>
        <view class="form-row time-row">
          <view class="row-label-wrap"><text class="field-icon">始</text><text class="row-label">开始</text></view>
          <view class="date-pair">
            <picker class="date-picker" mode="date" value="{{startDateKey}}" bindchange="onStartDateChange">
              <text class="date-chip">{{startDate}}</text>
            </picker>
            <picker class="time-picker" wx:if="{{!allDay}}" mode="time" value="{{startTime}}" bindchange="onStartTimeChange">
              <text class="date-chip time-chip">{{startTime}}</text>
            </picker>
          </view>
        </view>
        <view class="form-row time-row no-border">
          <view class="row-label-wrap"><text class="field-icon">止</text><text class="row-label">结束</text></view>
          <view class="date-pair">
            <picker class="date-picker" mode="date" value="{{endDateKey}}" disabled="{{allDay}}" bindchange="onEndDateChange">
              <text class="date-chip {{allDay ? 'locked' : ''}}">{{endDate}}</text>
            </picker>
            <picker class="time-picker" wx:if="{{!allDay}}" mode="time" value="{{endTime}}" bindchange="onEndTimeChange">
              <text class="date-chip time-chip">{{endTime}}</text>
            </picker>
          </view>
        </view>
        <text class="field-error time-error" wx:if="{{formErrorTime}}">{{formErrorTime}}</text>
      </view>

      <view class="form-section-head">
        <text class="section-kicker">提醒与补充</text>
        <text class="section-hint">低频选项保留在下方</text>
      </view>
      <picker mode="selector" range="{{repeatOptionLabels}}" bindchange="onRepeatChange">
        <view class="form-card single-row">
          <view class="row-label-wrap"><text class="field-icon muted-icon">复</text><text>重复</text></view>
          <text class="select-value">{{repeatLabel}}</text>
        </view>
      </picker>

      <view class="form-card" wx:if="{{repeatValue !== 'never'}}">
        <view class="form-row">
          <view class="row-label-wrap"><text class="field-icon muted-icon">止</text><text>重复结束</text></view>
          <text class="select-value">{{repeatEndMode}}</text>
        </view>
        <view class="form-row no-border">
          <view class="row-label-wrap"><text class="field-icon muted-icon">日</text><text>结束日期</text></view>
          <picker mode="date" value="{{repeatEndDateKey}}" bindchange="onRepeatEndDateChange">
            <text class="date-chip">{{repeatEndDate}}</text>
          </picker>
        </view>
      </view>

      <picker mode="selector" range="{{reminderOptions}}" bindchange="onReminderChange">
        <view class="form-card single-row">
          <view class="row-label-wrap"><text class="field-icon muted-icon">铃</text><text>提醒</text></view>
          <text class="select-value">{{reminder}}</text>
        </view>
      </picker>

      <view class="form-card title-card">
        <view class="input-row {{activeField === 'url' ? 'is-active' : ''}}">
          <text class="field-icon muted-icon">链</text>
          <input class="field-input" placeholder="链接" value="{{url}}" data-key="url" data-field="url" bindinput="updateField" bindfocus="setActiveField" bindblur="clearActiveField" />
        </view>
        <view class="input-row note-row no-border {{activeField === 'note' ? 'is-active' : ''}}">
          <text class="field-icon muted-icon">注</text>
          <textarea class="note-input" placeholder="备注" value="{{note}}" data-key="note" data-field="note" bindinput="updateField" bindfocus="setActiveField" bindblur="clearActiveField"></textarea>
        </view>
      </view>

      <view wx:if="{{pageMode === 'edit'}}" class="form-card delete-row" bindtap="deleteCurrentSchedule">
        <text class="delete-row-text">删除日程</text>
      </view>
      <view wx:if="{{pageMode === 'edit'}}" class="edit-bottom-spacer"></view>
    </view>
  </scroll-view>

  <view wx:if="{{pageMode !== 'edit'}}" class="bottom-input">
    <view class="long-input-wrap {{activeField === 'longText' ? 'is-active' : ''}}">
      <textarea class="long-input" placeholder="粘贴会议、任务或课程要求" value="{{longText}}" data-key="longText" data-field="longText" disabled="{{isParsingSchedule || isRecognizingVoice}}" bindinput="updateField" bindfocus="setActiveField" bindblur="onLongTextBlur"></textarea>
      <text class="parse-tip" wx:if="{{parseTip}}">{{parseTip}}</text>
    </view>
    <button class="voice-button {{isRecordingVoice ? 'recording' : ''}}" loading="{{isRecognizingVoice}}" disabled="{{isParsingSchedule || isRecognizingVoice}}" bindtap="startVoice" aria-label="智能录入">
      <view class="mic-stem"></view>
      <view class="mic-base"></view>
    </button>
  </view>
</view>
