.add-page {
  min-height: 100vh;
  padding: 26rpx 36rpx 220rpx;
  background: #f4f3f8;
  color: #111827;
}

.add-top {
  display: grid;
  grid-template-columns: 144rpx 1fr 144rpx;
  align-items: center;
  margin-bottom: 58rpx;
}

.plain {
  margin: 0;
  padding: 0;
  background: transparent;
  font-size: 34rpx;
  line-height: 1.4;
}

.cancel,
.back-action,
.done-action {
  color: #ef4444;
}

.cancel {
  text-align: left;
}

.add-title,
.custom-title {
  min-width: 0;
  overflow: hidden;
  color: #111827;
  font-size: 38rpx;
  font-weight: 800;
  text-align: center;
  text-overflow: clip;
  white-space: nowrap;
}

.add-action {
  color: #ef4444;
  text-align: right;
}

.form-card {
  overflow: hidden;
  margin-bottom: 34rpx;
  border-radius: 18rpx;
  background: #ffffff;
}

.title-card {
  padding: 0 36rpx;
}

.field-input {
  min-height: 92rpx;
  border-bottom: 1rpx solid #e5e7eb;
  color: #111827;
  font-size: 34rpx;
}

.title-input {
  font-size: 36rpx;
}

.no-border {
  border-bottom: 0;
}

.form-row,
.single-row {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  min-height: 92rpx;
  padding: 0 36rpx;
  border-bottom: 1rpx solid #e5e7eb;
  color: #111827;
  font-size: 34rpx;
  text-align: left;
}

.single-row {
  border-bottom: 0;
}

.as-button {
  line-height: normal;
}

.date-pair {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  max-width: 500rpx;
}

.date-chip {
  display: block;
  min-width: 210rpx;
  padding: 14rpx 18rpx;
  border-radius: 12rpx;
  background: #f0f0f2;
  color: #111827;
  font-size: 30rpx;
  text-align: center;
  white-space: nowrap;
}

.time-chip {
  min-width: 86rpx;
}

.locked {
  color: #6b7280;
}

.value-muted {
  color: #8b8f98;
}

.select-value {
  color: #111827;
  font-size: 34rpx;
  font-weight: 400;
  white-space: nowrap;
}

.blue-dot {
  display: inline-block;
  width: 20rpx;
  height: 20rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: #38bdf8;
  vertical-align: middle;
}

.note-input {
  box-sizing: border-box;
  width: 100%;
  min-height: 120rpx;
  padding: 22rpx 0;
  color: #111827;
  font-size: 34rpx;
}

.bottom-input {
  position: fixed;
  z-index: 10;
  left: 36rpx;
  right: 36rpx;
  bottom: 36rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.long-input {
  box-sizing: border-box;
  flex: 1;
  min-height: 104rpx;
  max-height: 160rpx;
  padding: 20rpx 24rpx;
  border-radius: 26rpx;
  background: #ffffff;
  color: #111827;
  font-size: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.08);
}

.voice-button {
  position: relative;
  flex: 0 0 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  min-width: 104rpx;
  min-height: 104rpx;
  margin: 0;
  padding: 0;
  overflow: visible;
  border-radius: 50%;
  background: #ef4444;
  line-height: 1;
  box-shadow: 0 16rpx 32rpx rgba(239, 68, 68, 0.28);
}

.mic-stem {
  position: absolute;
  left: 39rpx;
  top: 21rpx;
  width: 26rpx;
  height: 40rpx;
  border-radius: 18rpx;
  background: #f3f4f6;
}

.mic-base {
  position: absolute;
  left: 23rpx;
  top: 58rpx;
  width: 44rpx;
  height: 24rpx;
  border-bottom: 8rpx solid #f3f4f6;
  border-left: 8rpx solid #f3f4f6;
  border-right: 8rpx solid #f3f4f6;
  border-radius: 0 0 30rpx 30rpx;
}

.modal-mask {
  position: fixed;
  z-index: 30;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  background: rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(10rpx);
}

.repeat-sheet {
  width: 440rpx;
  margin-top: 332rpx;
  overflow: hidden;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 24rpx 80rpx rgba(15, 23, 42, 0.16);
}

.repeat-option {
  box-sizing: border-box;
  display: grid;
  grid-template-columns: 64rpx 1fr;
  align-items: center;
  width: 100%;
  min-height: 94rpx;
  padding: 0 36rpx;
  border-bottom: 1rpx solid #d8dbe2;
  color: #111827;
  font-size: 34rpx;
  text-align: left;
}

.repeat-option:last-child {
  border-top: 14rpx solid #eef0f5;
  border-bottom: 0;
}

.check {
  color: #111827;
  font-size: 40rpx;
  font-weight: 700;
}

.custom-panel {
  box-sizing: border-box;
  width: 100%;
  min-height: 100vh;
  padding: 26rpx 36rpx 80rpx;
  background: #f4f3f8;
}

.custom-top {
  display: grid;
  grid-template-columns: 220rpx 1fr 120rpx;
  align-items: center;
  margin-bottom: 112rpx;
}

.back-action {
  text-align: left;
}

.done-action {
  text-align: right;
}

.custom-card {
  overflow: hidden;
  border-radius: 18rpx;
  background: #ffffff;
}

.custom-row {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 0 36rpx;
  border-bottom: 1rpx solid #e5e7eb;
  font-size: 34rpx;
}

.custom-summary {
  color: #ef4444;
}

.repeat-picker {
  width: 100%;
  height: 360rpx;
}

.picker-indicator {
  height: 86rpx;
  background: rgba(244, 243, 248, 0.92);
  border-radius: 14rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 86rpx;
  color: #111827;
  font-size: 42rpx;
}

.custom-tip {
  margin: 28rpx 36rpx;
  color: #8b8f98;
  font-size: 28rpx;
}
