.page {
  position: relative;
  box-sizing: border-box;
  height: 100vh;
  overflow: hidden;
  background: #f8fafc;
  color: #111827;
}

.mine-scroll {
  height: 100vh;
  box-sizing: border-box;
  padding: calc(24rpx + env(safe-area-inset-top)) 28rpx calc(34rpx + env(safe-area-inset-bottom));
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  margin: 0 4rpx 14rpx;
  color: #64748b;
  font-size: 28rpx;
  font-weight: 800;
}

.card {
  box-sizing: border-box;
  padding: 28rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
}

.row-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.muted {
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.35;
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 30rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 20rpx;
  background: #ffffff;
}

.avatar {
  flex: 0 0 auto;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #ef4444;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 96rpx;
  text-align: center;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-name,
.auth-title,
.note-entry-title,
.note-entry-desc {
  display: block;
}

.profile-name {
  margin-bottom: 8rpx;
  font-size: 36rpx;
  font-weight: 800;
}

.link-row {
  min-height: 64rpx;
}

.auth-title {
  margin-bottom: 8rpx;
  font-weight: 700;
}

.mini-button {
  min-width: 120rpx;
  height: 58rpx;
  border-radius: 12rpx;
  background: #e0f2fe;
  color: #0369a1;
  font-size: 24rpx;
  line-height: 58rpx;
}

.form-hint {
  padding: 16rpx 20rpx;
  border-left: 4rpx solid #3b82f6;
  border-radius: 12rpx;
  background: #f0f9ff;
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.6;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  margin-bottom: 10rpx;
  color: #334155;
  font-size: 26rpx;
  font-weight: 600;
}

.form-input {
  box-sizing: border-box;
  width: 100%;
  height: 76rpx;
  padding: 0 24rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #1e293b;
  font-size: 28rpx;
}

.form-divider {
  height: 1rpx;
  margin: 24rpx 0;
  background: #e2e8f0;
}

.save-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  margin-top: 20rpx;
  border-radius: 16rpx;
  background: #ef4444;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
}

.save-btn[disabled] {
  background: #fca5a5;
}

.note-entry {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 150rpx;
  padding: 30rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.note-entry-main {
  flex: 1;
  min-width: 0;
}

.note-entry-title {
  margin-bottom: 14rpx;
  color: #111827;
  font-size: 36rpx;
  font-weight: 800;
}

.note-entry-desc {
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.4;
}

.note-entry-side {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.note-count {
  min-width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #fee2e2;
  color: #ef4444;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 52rpx;
  text-align: center;
}

.note-arrow {
  color: #94a3b8;
  font-size: 52rpx;
  line-height: 1;
}

.logout-btn {
  min-width: 120rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border: 1rpx solid #fecaca;
  border-radius: 12rpx;
  background: #fef2f2;
  color: #ef4444;
  font-size: 24rpx;
  line-height: 58rpx;
}

.course-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  background: rgba(15, 23, 42, 0.34);
}

.course-panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(22rpx + env(safe-area-inset-bottom));
  z-index: 21;
  box-sizing: border-box;
  max-height: 76vh;
  padding: 26rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.18);
}

.course-panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.course-panel-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 800;
}

.course-close {
  flex: 0 0 auto;
  min-width: 112rpx;
  height: 56rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 12rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 24rpx;
  line-height: 56rpx;
}

.course-close::after,
.confirm-import::after,
.mini-button::after,
.save-btn::after,
.logout-btn::after {
  border: 0;
}

.course-list {
  max-height: 48vh;
}

.course-card {
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
  padding: 22rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  background: #f8fafc;
}

.course-card.disabled {
  opacity: 0.58;
}

.course-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.course-meta {
  color: #475569;
  font-size: 25rpx;
  line-height: 1.35;
}

.course-warning {
  color: #ef4444;
  font-size: 24rpx;
  font-weight: 700;
}

.warning-box {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 8rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #fff7ed;
  color: #c2410c;
  font-size: 24rpx;
  line-height: 1.4;
}

.confirm-import {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  margin: 20rpx 0 0;
  padding: 0;
  border-radius: 14rpx;
  background: #ef4444;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 82rpx;
}
