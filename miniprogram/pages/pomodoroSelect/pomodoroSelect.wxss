.select-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 0 28rpx calc(40rpx + env(safe-area-inset-bottom));
  background: #f8fafc;
}

.topbar {
  position: relative;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 0 -28rpx 42rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  justify-content: center;
}

.back {
  position: absolute;
  left: 28rpx;
  min-width: 104rpx;
  height: 64rpx;
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 64rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
}

.back::after {
  border: 0;
}

.top-title {
  font-size: 38rpx;
  font-weight: 900;
}

.select-board {
  margin-top: 0;
}

.select-row {
  display: flex;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.choice {
  box-sizing: border-box;
  flex: 1;
  min-width: 0;
  min-height: 310rpx;
  padding: 34rpx 24rpx;
  border-radius: 28rpx;
  text-align: left;
  box-shadow: 0 18rpx 38rpx rgba(15, 23, 42, 0.08);
}

.study { background: #fef3c7; }
.sport { background: #dcfce7; }
.entertainment { background: #fce7f3; }
.sleep { background: #e0e7ff; }

.choice-icon,
.choice-title,
.choice-desc {
  display: block;
}

.choice-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
  text-align: center;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 72rpx;
}

.choice-title {
  margin-top: 34rpx;
  font-size: 42rpx;
  font-weight: 900;
}

.choice-desc {
  margin-top: 12rpx;
  color: #475569;
  font-size: 25rpx;
  line-height: 1.45;
}
