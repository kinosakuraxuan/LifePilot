.discover-page {
  padding-bottom: 40rpx;
}

.discover-hero {
  padding: 34rpx 30rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #fee2e2, #ffffff);
}

.hero-title {
  margin: 10rpx 0;
  font-size: 44rpx;
  font-weight: 800;
}

.hero-subtitle {
  color: #475569;
}

.quadrant-board {
  position: relative;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin: 30rpx 0;
  min-height: 560rpx;
}

.quadrant {
  box-sizing: border-box;
  min-height: 270rpx;
  padding: 30rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.07);
}

.q-entertainment {
  background: #fff7ed;
}

.q-sleep {
  background: #f5f3ff;
}

.q-sport {
  background: #f0fdf4;
}

.q-music {
  background: #fff1f2;
}

.quadrant-title {
  font-size: 36rpx;
  font-weight: 900;
}

.quadrant-value {
  margin: 28rpx 0 12rpx;
  font-size: 50rpx;
  font-weight: 900;
}

.quadrant-desc {
  color: #64748b;
  font-size: 26rpx;
}

.report-center {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 156rpx;
  height: 156rpx;
  min-width: 156rpx;
  min-height: 156rpx;
  padding: 0;
  border-radius: 50%;
  background: #ef4444;
  color: #ffffff;
  box-shadow: 0 20rpx 42rpx rgba(239, 68, 68, 0.34);
}

.report-main {
  font-size: 36rpx;
  font-weight: 900;
}

.report-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  opacity: 0.86;
}

.advice {
  color: #334155;
  line-height: 1.7;
}
