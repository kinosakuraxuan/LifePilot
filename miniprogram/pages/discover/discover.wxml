<scroll-view class="discover-page" type="list" scroll-y="true">
  <view class="discover-hero">
    <view>
      <text class="muted">发现</text>
      <text class="hero-title">生活象限</text>
      <text class="hero-subtitle">{{overview.weekRange || '本周'}} · 得分 {{overview.totalScore || 0}}</text>
    </view>
    <button class="note-entry" bindtap="goBoundless">
      <text>笔记</text>
    </button>
  </view>

  <view class="quadrant-board">
    <view class="quadrant-row">
      <view class="quadrant {{quadrants[0].cls}}" data-path="{{quadrants[0].path}}" bindtap="goModule">
        <text class="quadrant-kicker">专注</text>
        <text class="quadrant-title">{{quadrants[0].title}}</text>
        <text class="quadrant-value">{{quadrants[0].value}}</text>
        <text class="quadrant-desc" overflow="ellipsis" max-lines="2">{{quadrants[0].desc}}</text>
      </view>
      <view class="quadrant {{quadrants[1].cls}}" data-path="{{quadrants[1].path}}" bindtap="goModule">
        <text class="quadrant-kicker">活动</text>
        <text class="quadrant-title">{{quadrants[1].title}}</text>
        <text class="quadrant-value">{{quadrants[1].value}}</text>
        <text class="quadrant-desc" overflow="ellipsis" max-lines="2">{{quadrants[1].desc}}</text>
      </view>
    </view>

    <view class="quadrant-row">
      <view class="quadrant {{quadrants[2].cls}}" data-path="{{quadrants[2].path}}" bindtap="goModule">
        <text class="quadrant-kicker">娱乐</text>
        <text class="quadrant-title">{{quadrants[2].title}}</text>
        <text class="quadrant-value">{{quadrants[2].value}}</text>
        <text class="quadrant-desc" overflow="ellipsis" max-lines="2">{{quadrants[2].desc}}</text>
      </view>
      <view class="quadrant {{quadrants[3].cls}}" data-path="{{quadrants[3].path}}" bindtap="goModule">
        <text class="quadrant-kicker">休息</text>
        <text class="quadrant-title">{{quadrants[3].title}}</text>
        <text class="quadrant-value">{{quadrants[3].value}}</text>
        <text class="quadrant-desc" overflow="ellipsis" max-lines="2">{{quadrants[3].desc}}</text>
      </view>
    </view>

    <button class="pomodoro-center" bindtap="goPomodoro">
      <text class="pomodoro-main">番茄钟</text>
      <text class="pomodoro-sub">开始</text>
    </button>
  </view>

  <view class="section">
    <text class="section-title">AI 提醒</text>
    <view class="card advice">
      <text>{{overview.summary || '添加记录后会生成更有用的本周提醒。'}}</text>
    </view>
  </view>
</scroll-view>
